NAME zlib
VERSION 1.3.2
SOURCE URL https://github.com/madler/zlib/releases/download/v1.3.2/zlib-1.3.2.tar.gz
SHA256 bb329a0a2cd0274d05519d61c667c062e06990d72e125ee2dfa8de64f0119d16
BUILD_SYSTEM CMAKE
CMAKE_DEFINE CMAKE_C_COMPILER=clang
CMAKE_DEFINE CMAKE_POSITION_INDEPENDENT_CODE=ON
CMAKE_DEFINE BUILD_SHARED_LIBS=OFF
CMAKE_DEFINE ZLIB_BUILD_TESTING=OFF
TARGET zlib::zlib STATIC lib/libz.a INTERFACE include
